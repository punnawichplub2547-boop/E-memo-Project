THAILLM_API_KEY=
GROQ_API_KEY=

# Optional email notification delivery. In-app notifications still work when disabled.
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="HR&GA E-Memo <no-reply@example.com>"
EMAIL_REPLY_TO=
# Set if the mail server's TLS cert CN/SAN differs from SMTP_HOST (vanity host).
# e.g. SMTP_HOST=mail.car-1996.com but the cert is for hmail02.readyidc.cloud.
# Keeps cert validation ON, just tells Node the real name to check.
SMTP_TLS_SERVERNAME=
# Escape hatch only — set to false to skip TLS cert validation (self-signed). Insecure.
SMTP_TLS_REJECT_UNAUTHORIZED=

# --- Telegram bot (server-side; fill from BotFather) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=

# --- External access (set on the prod host only) ---
# Stable public origin behind the Cloudflare Named Tunnel.
APP_PUBLIC_BASE_URL=https://memo.car-1996.com
# Send the session cookie over HTTPS only. MUST stay false on local http://localhost.
AUTH_COOKIE_SECURE=false
